# .env.example
# Ce fichier est un MODELE des variables d'environnement du projet.
# - Il peut être versionné dans Git (aucun secret réel dedans).
# - Copie-le dans un vrai fichier `.env` pour ton environnement local.
# - Ne mets jamais de clés/API réelles dans ce fichier exemple.

# URL de l'API utilisée par le dashboard (exemple)
# En local : http://127.0.0.1:5001/api
# En production : https://scotty-dashboard-api.onrender.com/api
API_BASE_URL=https://scotty-dashboard-api.onrender.com/api
